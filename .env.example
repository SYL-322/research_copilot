# OpenAI (never commit real keys — copy this file to .env and fill in locally)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini # used for first-pass topic scan and digest by default

# Data layout (defaults to ./data under project root if unset)
# RESEARCH_COPILOT_DATA_DIR=/absolute/path/to/data

# SQLite filename inside the data directory
# DATABASE_FILENAME=research_copilot.db

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API timeouts (seconds)
HTTP_TIMEOUT=60.0

# Semantic Scholar (optional; public API often works without a key)
# SEMANTIC_SCHOLAR_API_KEY=

# arXiv uses public API; no key required
